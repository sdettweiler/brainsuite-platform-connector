modules = ["python-3.12", "nodejs-20", "bash", "web", "postgresql-16"]

[nix]
channel = "stable-25_05"
packages = ["deno", "ffmpeg", "ffmpeg-full", "imagemagick", "libxcrypt"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5904
externalPort = 3000

[deployment]
run = ["bash", "replit_start.sh"]
deploymentTarget = "vm"
build = ["bash", "build.sh"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start App"

[[workflows.workflow]]
name = "Start App"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash replit_start.sh"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[agent]
expertMode = true
integrations = ["javascript_object_storage:2.0.0"]

[userenv]

