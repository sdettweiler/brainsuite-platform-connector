# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=brainsuite
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=brainsuite

# ─── Backend Security ─────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-32-char-random-string

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# ─── Application URL ──────────────────────────────────────────────────────────
# Set to your public URL in production (e.g., https://app.example.com)
BASE_URL=http://localhost:8000

# Delay scheduler start to allow network readiness (seconds). Set to 15 in production.
SCHEDULER_STARTUP_DELAY_SECONDS=0

# ─── Redis ────────────────────────────────────────────────────────────────────
# Docker Compose (internal): redis://redis:6379/0
# Native / external:        redis://localhost:6379/0
REDIS_URL=redis://redis:6379/0

# ─── Object Storage (S3 / MinIO) ──────────────────────────────────────────────
# For local dev with MinIO: use the defaults below
# For production with AWS S3: set real credentials and remove S3_ENDPOINT_URL
# Note: S3_ENDPOINT_URL is the internal Docker endpoint (http://minio:9000).
#       Presigned URLs generated by the backend will use this host — they are
#       for internal/backend use only in Phase 1. Public presigned URLs require
#       a separate S3_PUBLIC_ENDPOINT_URL (Phase 3 work).
S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET_NAME=brainsuite-assets
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
AWS_REGION=us-east-1

# ─── Meta / Facebook ──────────────────────────────────────────────────────────
# Create at: https://developers.facebook.com/apps/
# Required permissions: ads_read, ads_management, business_management, read_insights, pages_read_engagement
# App type: Business
META_APP_ID=
META_APP_SECRET=
# Add to Valid OAuth Redirect URIs in Facebook App Settings:
META_REDIRECT_URI=http://localhost:8000/api/v1/platforms/oauth/callback/meta

# ─── TikTok ───────────────────────────────────────────────────────────────────
# Create at: https://ads.tiktok.com/marketing_api/apps/
# Required scopes: ad.read, campaign.read, report.read
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
# Add to Redirect URI in TikTok App Settings:
TIKTOK_REDIRECT_URI=http://localhost:8000/api/v1/platforms/oauth/callback/tiktok

# ─── Google / YouTube ─────────────────────────────────────────────────────────
# Create OAuth Client at: https://console.developers.google.com/
# App type: Web application
# Required APIs: Google Ads API, YouTube Data API v3
# Required scopes: https://www.googleapis.com/auth/adwords, https://www.googleapis.com/auth/youtube.readonly
# Add to Authorized redirect URIs in Google OAuth Client:
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/platforms/oauth/callback/google
# Get Developer Token at: https://ads.google.com/nav/selectaccount (My account > Tools > API Center)
GOOGLE_DEVELOPER_TOKEN=

# ─── Currency Conversion ──────────────────────────────────────────────────────
# Get free key at: https://www.exchangerate-api.com/ (1500 req/month free)
# Falls back to frankfurter.app (free, no key) if not set
EXCHANGE_RATE_API_KEY=
